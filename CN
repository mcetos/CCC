7 Distance Vector Program

# initial cost (A to A,B,C)
cost = [0, 2, 5]
print("Initial cost:", cost)
# assume B tells A that cost to C = 1
# so new path A → B → C = 2 + 1 = 3
new_cost = cost[1] + 1
# update using minimum
if new_cost < cost[2]:
    cost[2] = new_cost
print("Updated cost:", cost)




