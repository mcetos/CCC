2  TCP Echo Program
Server (echo_server.py)

import socket
s = socket.socket()
s.bind(("127.0.0.1", 12345))
s.listen(1)
print("Server listening on 127.0.0.1:12345")
c, addr = s.accept()
print("Connected by", addr)
data = c.recv(1024).decode()
print("Received:", data)
c.send(data.encode())
c.close()

Client (echo_client.py)

import socket
