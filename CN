8 Simple DNS Program (UDP)
Server (dns_server.py)

import socket
# simple DNS table
dns = {
    "google.com": "8.8.8.8",
    "example.com": "93.184.216.34"
}
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", 1237))
print("DNS Server running...")
while True:
    data, addr = s.recvfrom(1024)
    name = data.decode()
    print("Request for:", name)
    ip = dns.get(name, "Not found")
    s.sendto(ip.encode(), addr)

Client (dns_client.py)

import socket
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
name = input("Enter domain: ")
s.sendto(name.encode(), ("127.0.0.1", 1237))
ip = s.recv(1024).decode()
print("IP Address:", ip)
s.close()



